# =============================================================
# Production environment for crm.llve.ru
# Copy to .env.prod and fill in all required values
# =============================================================

# --- JWT ---
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Database ---
POSTGRES_USER=crm
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD
POSTGRES_DB=crm_db

# --- Redis ---
REDIS_PASSWORD=REPLACE_WITH_STRONG_REDIS_PASSWORD

# --- Telegram Bot ---
BOT_TOKEN=REPLACE_WITH_BOT_TOKEN_FROM_BOTFATHER
WEBHOOK_URL=https://crm.llve.ru/api/v1/telegram/webhook
INTERNAL_BOT_TOKEN=REPLACE_WITH_64_CHAR_RANDOM_STRING

# --- CORS ---
CORS_ORIGINS=["https://crm.llve.ru"]

# --- Superadmin (created on first startup) ---
SUPERADMIN_EMAIL=admin@crm.llve.ru
SUPERADMIN_PASSWORD=REPLACE_WITH_STRONG_ADMIN_PASSWORD
